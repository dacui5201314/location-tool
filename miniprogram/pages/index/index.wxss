.container {
  padding: 48rpx 32rpx;
}

.hero {
  text-align: center;
  margin-bottom: 56rpx;
}

.brand {
  font-size: 56rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.tagline {
  font-size: 32rpx;
  color: #334155;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.6;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.primary-btn {
  width: 100%;
  background: #0f172a;
  color: #fff;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
}

.outline-btn {
  width: 100%;
  background: #fff;
  color: #0f172a;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
}

.footer-note {
  margin-top: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}
