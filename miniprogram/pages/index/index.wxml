<view class="container">
  <view class="header">
    <view class="title">址得选</view>
    <view class="status {{loggedIn ? 'online' : 'offline'}}">
      {{ loggedIn ? '已登录' : '未登录' }}
    </view>
  </view>

  <view class="card" wx:if="{{loggedIn}}">
    <view class="section-title">账户信息</view>
    <view class="info-row">
      <text class="label">余额</text>
      <text class="value">{{balanceCredits}} 点</text>
    </view>
    <view class="info-row">
      <text class="label">OpenID</text>
      <text class="value muted">{{maskedOpenid}}</text>
    </view>
    <view class="gift-note" wx:if="{{giftNote}}">{{giftNote}}</view>
  </view>

  <view class="card actions">
    <button class="action-btn" bindtap="checkHealth">检查后端健康</button>
    <view class="action-result" wx:if="{{healthResult}}">{{healthResult}}</view>

    <button class="action-btn" bindtap="fetchRecords">获取我的记录</button>
    <view class="action-result" wx:if="{{recordsResult}}">{{recordsResult}}</view>
  </view>

  <view class="card actions" wx:if="{{loggedIn}}">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <view class="card" wx:if="{{!loggedIn}}">
    <button class="login-link" bindtap="goLogin">去登录</button>
  </view>
</view>
