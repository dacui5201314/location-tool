.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx;
}

.card {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  text-align: center;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 60rpx;
}

.login-btn {
  width: 100%;
  border-radius: 16rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  background-color: #07c160;
  color: #fff;
}

.login-btn[disabled] {
  background-color: #86dba9;
}

.error {
  margin-top: 32rpx;
  padding: 20rpx;
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  border-radius: 12rpx;
  color: #dc2626;
  font-size: 26rpx;
  text-align: center;
}

.hint {
  margin-top: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
}
