# ============================================================
# AI 商业选址决策系统 — 根目录 .gitignore
# ============================================================

# IDE / 编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# OS 系统文件
.DS_Store
Thumbs.db
Desktop.ini

# Claude Code 工作区
.claude/

# 环境变量（含密钥）
.env
backend/.env
backend/c4_test.json

# 备份目录
zhidexuan/
backend/logs/

# Logo 素材（未跟踪图片，不上传仓库）
logo-1/

# 阶段性规划文档（本地参考，不上传仓库）
第二阶段执行计划.md

# 本地数据库（防止 SQLite 入库）
backend/location_tool.db
backend/location_tool.db-wal
backend/location_tool.db-shm

# 运行时存储（报告/上传文件）
backend/storage/

# Python 编译缓存
__pycache__/
*.pyc

# Tracked admin brand asset used by /admin favicon/logo.
!backend/storage/
!backend/storage/assets/
!backend/storage/assets/admin-logo.png
