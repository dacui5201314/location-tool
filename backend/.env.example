# =============================================================================
# AI 商业选址决策系统 — 环境变量配置模板
# 复制为 .env 并填入真实值后启动后端服务
# =============================================================================

# -------------------- 大模型配置（当前生效）--------------------
# ★ 推荐：只需配置以下 4 项即可切换任意兼容 OpenAI API 的模型供应商
LLM_PROVIDER=deepseek                   # 提供商: deepseek / openai / gemini / kimi / minimax / zhipu
LLM_MODEL=deepseek-chat                 # 模型名
LLM_BASE_URL=https://api.deepseek.com/v1 # API 地址
LLM_API_KEY=sk-xxx                      # ★ 全局 API Key（当前 LLM_PROVIDER 的密钥）

# -------------------- 各平台独立 Key（旧版兼容，保留可用）--------------------
# 注意：以下 Key 仅供前端"手动选 Provider"模式使用。
# 如果已配置 LLM_API_KEY 且不切换 Provider，则无需填写下方 Key。
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
KIMI_API_KEY=your_kimi_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# -------------------- 高德地图 Web API --------------------
AMAP_WEB_KEY=xxx                        # 高德 Web 服务 Key（后端 POI 采集）
AMAP_SECURITY_CODE=xxx                  # 高德安全密钥（JS API 数字签名）

# -------------------- JWT 鉴权 --------------------
JWT_SECRET=change-this-to-a-random-secret-in-production  # ★ 生产环境务必替换为随机长字符串
JWT_EXPIRY_HOURS=72                     # Token 有效期（小时），默认 72h

# -------------------- CORS 跨域（生产环境）--------------------
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# -------------------- 微信公众号网页授权 --------------------
WECHAT_MP_APPID=wx_your_appid_here      # 公众号 AppID
WECHAT_MP_SECRET=your_appsecret_here    # 公众号 AppSecret

# -------------------- 新用户注册奖励 --------------------
SIGNUP_BONUS_CREDITS=3                  # 注册赠送永久点数（默认 3 次）
SIGNUP_FREE_CREDITS=1                   # 注册赠送体验点数（24h 过期）
REGISTER_BONUS_CREDITS=3                # 同上，别名兼容

# -------------------- 管理后台 --------------------
ADMIN_PASSWORD=your_secure_password     # ★ 管理员登录密码，务必修改默认值
