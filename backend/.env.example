# =============================================================================
# 址得选 AI 选址分析平台 — 环境变量配置模板
# 复制为 backend/.env 并填入真实值后启动后端服务
# =============================================================================

# -------------------- 大模型配置 --------------------
# Key 优先级：provider 专用 env > 后台 DB ai_key > LLM_API_KEY 兜底 > 未配置
LLM_PROVIDER=deepseek                   # deepseek | openai | gemini | kimi | minimax | zhipu
LLM_MODEL=deepseek-chat                 # 模型名称
LLM_BASE_URL=https://api.deepseek.com/v1 # API 地址
LLM_API_KEY=sk-your-key-here            # ★ 兜底 Key（仅在无 provider 专用 env / 后台 AI Key 时使用）

# -------------------- 各平台独立 Key（推荐优先使用）--------------------
# 如果设置了 provider 专用 Key，会优先生效，不会走 LLM_API_KEY 兜底
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=
# kimi 兼容 MOONSHOT_API_KEY
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
ZHIPU_API_KEY=

# -------------------- 高德地图 Web API --------------------
AMAP_WEB_KEY=your_amap_web_key          # 高德 Web 服务 Key（后端 POI 采集）
AMAP_SECURITY_CODE=your_amap_sec_code   # 高德安全密钥（JS API 数字签名）

# -------------------- JWT 鉴权 --------------------
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRY_HOURS=168                    # 普通用户 Token 有效期（小时），默认 7 天
ADMIN_JWT_EXPIRY_HOURS=4                # 管理员 Token 有效期（小时），默认 4 小时

# -------------------- 可信代理 IP（X-Forwarded-For 信任边界）--------------------
# TRUSTED_PROXY_IPS=127.0.0.1,::1
# 后端仅信任这些来源的 X-Forwarded-For。部署在云负载均衡后，填写代理内网 IP/CIDR。

# -------------------- CORS 跨域（生产环境配置）--------------------
# ENVIRONMENT=production 时 CORS_ORIGINS 必须填写具体域名，不允许为空或使用 "*"
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# -------------------- 调试开关（仅限本地开发）--------------------
# ALLOW_CLIENT_REALDATA_FALLBACK=false
# 允许客户端直接传入 real_data 替代高德采集。生产环境禁止启用，开发环境按需开启。
# ENVIRONMENT=production 时该开关会导致启动失败。

# -------------------- 微信公众号网页授权（填入真实值后生效）--------------------
WECHAT_MP_APPID=
WECHAT_MP_SECRET=

# -------------------- 新用户注册奖励 --------------------
SIGNUP_BONUS_CREDITS=3                  # 注册赠送永久点数
SIGNUP_FREE_CREDITS=1                   # 注册赠送体验点数（24h 过期）
REGISTER_BONUS_CREDITS=3                # 别名兼容

# -------------------- 管理后台 --------------------
ADMIN_PASSWORD=your_secure_password     # ★ 管理员登录密码，生产环境务必修改
